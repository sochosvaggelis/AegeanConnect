{
  "name": "Application",
  "type": "object",
  "properties": {
    "job_id": {
      "type": "string",
      "description": "ID of the job applied to"
    },
    "job_title": {
      "type": "string",
      "description": "Title of the job"
    },
    "hotel_name": {
      "type": "string",
      "description": "Name of the hotel"
    },
    "hotel_user_id": {
      "type": "string",
      "description": "User ID of the hotel"
    },
    "applicant_name": {
      "type": "string",
      "description": "Name of the applicant"
    },
    "applicant_email": {
      "type": "string",
      "description": "Email of the applicant"
    },
    "cover_letter": {
      "type": "string",
      "description": "Cover letter text"
    },
    "resume_url": {
      "type": "string",
      "description": "URL to resume file"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "reviewed",
        "accepted",
        "rejected",
        "withdrawn"
      ],
      "default": "pending"
    }
  },
  "required": [
    "job_id",
    "job_title",
    "hotel_name",
    "hotel_user_id",
    "applicant_name",
    "applicant_email",
    "status"
  ]
}